     "text": [
      "6人のテストの平均点は53.3点です\n"
     ]
    }
   ],
   "source": [
    "numbers = []\n",
    "while True:\n",
    "    number = int(input(\"点数を入力してください: \"))\n",
    "\n",
    "    if number == -1:\n",
    "        break\n",
    "\n",
    "    numbers.append(number)\n",
    "\n",
    "size = len(numbers)\n",
    "if size != 0:\n",
    "    total = sum(numbers)\n",
    "    average = total / size\n",
    "    print(f\"{size}人のテストの平均点は{round(average, 1)}点です\")\n"
   ]
  }
 ],
