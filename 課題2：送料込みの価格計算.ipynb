     "text": [
      "送料として350円かかります\n",
      "送料込みの価格は2061円です。\n"
     ]
    }
   ],
   "source": [
    "price = int(input(\"税抜き価格を入力してください：\"))\n",
    "\n",
    "tax = 1.1  # 10%\n",
    "shipping = 350  # 送料\n",
    "payment = round(price * tax)\n",
    "\n",
    "if payment >= 2000:\n",
    "    print(\"送料は無料です\")\n",
    "else:\n",
    "    payment += shipping\n",
    "    print(f\"送料として{shipping}円かかります\")\n",
    "\n",
    "print(f\"送料込みの価格は{payment}円です。\")"
   ]
  }
 ],
